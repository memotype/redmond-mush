# Copy this file to product/config/redmond.env or pass it with
# --config path/to/redmond.env.

# Path-like values in this file resolve relative to this config file.

# REDMOND_GAME_DIR defaults to the committed game dir under src/.
# REDMOND_GAME_DIR=../src/redmond_server/game

# Set REDMOND_DATABASE_URL to select PostgreSQL instead of SQLite.
# REDMOND_DATABASE_URL=postgres://redmond:change-me@127.0.0.1:5432/redmond

# Optional PostgreSQL backup overrides.
# REDMOND_PGBACKREST_COMMAND=pgbackrest
# REDMOND_PGBACKREST_STANZA=redmond
# REDMOND_BACKUP_DIR=../src/redmond_server/game/server/backups

# Optional wrapper-level runtime timeouts.
# REDMOND_STOP_TIMEOUT_SECONDS=20
# REDMOND_SHUTDOWN_GRACE_SECONDS=5
# REDMOND_RELOAD_TIMEOUT_SECONDS=30
