COMPOSE_PROJECT_NAME=redmond
POSTGRES_DB=redmond
POSTGRES_USER=redmond
POSTGRES_PASSWORD=change-me-local-postgres-password
#
# REDMOND_DATABASE_URL is the authoritative application connection string.
# Percent-encode the username, password, and database-name components when
# required by URI rules.
REDMOND_DATABASE_URL=postgres://redmond:change-me-local-postgres-password@postgres:5432/redmond
REDMOND_SECRET_KEY=change-me-local-redmond-secret-key
REDMOND_TELNET_PORT=4000
REDMOND_WEB_PORT=4001
REDMOND_WEBSOCKET_PORT=4002
